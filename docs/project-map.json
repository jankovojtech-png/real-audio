  "apis": [
    {
      "method": "GET",
      "path": "/api/stream",
      "file": "app/api/stream/route.ts",
      "auth": "none",
      "params": [{ "name": "id", "type": "string", "required": false, "default": "provence" }],
      "response": "audio/mpeg (infinite chunked)",
      "ffmpeg_flags": ["-reconnect 1", "-reconnect_streamed 1", "-reconnect_delay_max 5", "-icy 0", "-vn", "-c:a libmp3lame", "-b:a 128k", "-f mp3"],
      "cleanup": "request.signal abort → SIGKILL + PassThrough.destroy()"
    }
  ],

